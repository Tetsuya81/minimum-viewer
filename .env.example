# 必須
ACCESS_TOKEN={GITHUB_Personal_Access_Token}   # ↑で作ったPAT
REPO_URL=https://github.com/Tetsuya81/minimum-viewer

# おすすめ設定
RUNNER_NAME=minimum-viewer-runner
LABELS=self-hosted,linux,arm64,docker,ephemeral   # workflowでruns-on指定用
EPHEMERAL=true                                    # 1ジョブで自動消滅

# オプション（デフォルトでOK）
RUNNER_SCOPE=repo
RANDOM_RUNNER_SUFFIX=true   # 名前衝突防止でランダムsuffix付く
RUN_AS_ROOT=false           # セキュリティ重視ならtrue→falseに（推奨）
