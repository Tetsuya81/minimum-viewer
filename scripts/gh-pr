#!/usr/bin/env bash
set -e

BASE_BRANCH="${BASE_BRANCH:-master}"

# 1. ブランチ確認
branch="$(git branch --show-current)"
if [ "$branch" = "master" ] || [ "$branch" = "main" ]; then
  echo "Error: Currently on '$branch'. Switch to a feature branch." >&2
  exit 1
fi

# 2. コミット履歴の取得
commits="$(git log --oneline "$BASE_BRANCH..HEAD")"
if [ -z "$commits" ]; then
  echo "Error: No commits between $BASE_BRANCH and HEAD. Create at least one commit." >&2
  exit 1
fi

# 3. 差分サマリの取得
diff_stat="$(git diff "$BASE_BRANCH..HEAD" --stat)"

# 4. プレフィックスの自動判定
commit_msgs="$(git log "$BASE_BRANCH..HEAD" --format="%s%n%b")"
prefix="fix"
if echo "$commit_msgs" | grep -qE "BREAKING CHANGE|^[a-z]+(!\(|!:)"; then
  prefix="BREAKING CHANGE"
elif echo "$commit_msgs" | grep -qE "^feat(\([^)]*\))?!?:|^feat(\([^)]*\))?\s"; then
  prefix="feat"
fi

# title: ブランチ名から英語タイトルを生成（先頭の番号とハイフンを除去し、ハイフンをスペースに、先頭のみ大文字に）
raw_title="$(echo "$branch" | sed -E 's/^[0-9]+-//' | sed 's/-/ /g')"
# 先頭1文字を大文字に（BSD/macOS 互換）
first="$(echo "$raw_title" | cut -c1 | tr 'a-z' 'A-Z')"
rest="$(echo "$raw_title" | cut -c2-)"
title="$first$rest"

# 5. ボディ用 Summary（日本語）: 先頭コミットの subject から conventional プレフィックスを除いた部分を使用
first_subject="$(git log "$BASE_BRANCH..HEAD" --format="%s" -1)"
summary_line="$(echo "$first_subject" | sed -E 's/^[a-z]+(\([^)]*\))?!?: //')"

pr_title="$prefix: $title"
pr_body="## Summary
- $summary_line

## Commits
$commits
"

# 6. リモートへのプッシュと PR 作成
git push -u origin HEAD
gh pr create --title "$pr_title" --body "$pr_body"
echo ""
echo "PR created: $(gh pr view --json url -q .url)"
